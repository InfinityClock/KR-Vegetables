# ─────────────────────────────────────────────────────────────────────────────
# KR Vegetables & Fruits — Environment Variables
#
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
#
# Variables prefixed with VITE_ are embedded in the frontend bundle at
# build time and are visible to the browser. Only put non-sensitive public
# keys here (Supabase anon key, public VAPID key, etc.).
#
# All other variables are server-only (Vercel Edge Functions / Node.js)
# and must be set in Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, NEVER use the VITE_ prefix for this
# Used by all /api/* Vercel functions to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── App URL ───────────────────────────────────────────────────────────────────
# Production domain — used for CORS validation and payment redirect URLs
APP_URL=https://krvegetables.in

# Admin email — used as fallback in server-side auth checks
ADMIN_EMAIL=admin@krvegetables.in


# ── Zoho Payments ─────────────────────────────────────────────────────────────
# Create an OAuth "Self Client" app at: https://api-console.zoho.in/
# Required scopes: ZohoPay.payments.CREATE ZohoPay.payments.READ

# Your Zoho Payments account ID
# (from Zoho Payments → Settings → Account Details)
ZOHO_ACCOUNT_ID=your-zoho-account-id

# OAuth credentials from Zoho API Console
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# Long-lived refresh token (generated once via Zoho OAuth flow)
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# Webhook signing key
# (from Zoho Payments → Settings → Webhooks → Signing Key)
# MANDATORY — requests without a valid signature are rejected with 401
ZOHO_WEBHOOK_SECRET=your-zoho-webhook-signing-key

# Payment confirmation HMAC secret — any long random string
# Generate with: openssl rand -hex 32
# Embeds a signed token in Zoho success_url to verify genuine redirects
PAYMENT_CONFIRM_SECRET=your-random-secret-here


# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a VAPID key pair: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@krvegetables.in

# Public VAPID key also needed in the frontend bundle for push subscription
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key


# ── Google Maps (optional) ────────────────────────────────────────────────────
# Enables address autocomplete and GPS geocoding in checkout.
# If not set, the address search field is hidden and customers enter manually.
# Create at: https://console.cloud.google.com
# Enable: Maps JavaScript API + Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key


# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret used to authenticate Vercel cron job calls to /api/expire-offers
# Generate with: openssl rand -hex 32
# Set this in Vercel → Settings → Environment Variables
CRON_SECRET=your-cron-secret-here


# ── Store Contact (optional overrides) ────────────────────────────────────────
# If not set, defaults in src/constants/index.js are used
VITE_WHATSAPP_NUMBER=+919176260992
VITE_STORE_PHONE=+91 91762 60992
